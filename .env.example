# Supabase frontend
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Push notifikace – veřejný VAPID klíč pro browser subscription
VITE_VAPID_PUBLIC_KEY=your-public-vapid-key

# Vercel serverless funkce – nastav pouze ve Vercelu, ne do veřejného frontendu
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VAPID_PUBLIC_KEY=your-public-vapid-key
VAPID_PRIVATE_KEY=your-private-vapid-key
VAPID_SUBJECT=mailto:prace@rbgroup.cz
